# rtbit Docker configuration
RTBIT_DOWNLOADS=/mnt/data3/downloads/rtbit
RTBIT_COMPLETED=/mnt/data3/completed/rtbit

# Indexarr integration (optional)
# Set RTBIT_INDEXARR_ENABLED=true and provide the URL to enable torrent index browsing.
# RTBIT_INDEXARR_ENABLED=true
# RTBIT_INDEXARR_URL=http://indexarr:8080
# RTBIT_INDEXARR_API_KEY=your-api-key-here

# Indexarr-specific settings (for docker-compose.indexarr.yml)
# INDEXARR_SYNC_PEERS='["https://bootstrap.indexarr.net"]'
# INDEXARR_TORZNAB_API_KEY=
# INDEXARR_CONTRIBUTOR_RECOVERY_KEY=
